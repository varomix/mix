// Generic shape monomorphization. Each `Stack[T]` (etc.) instantiation
// gets its own concrete shape with its own methods, so float values use
// the correct ABI and shape methods on T dispatch correctly.

shape Box[T]
    val: T

    get() -> T
        val

shape Stack[T]
    items: [T]

    push!(v: T) ~
        items.push!(v)

    pop!() -> T ~
        items.pop!()

main()
    // Explicit instantiation
    a = Box[int](val: 42)
    print(a.get())

    // Float — was a runtime crash before monomorphization
    b = Box[float](val: 3.5)
    print(b.get())

    // Strings
    c = Box[str](val: "hello")
    print(c.get())

    // Inferred type from constructor args
    s! = Stack(items: [10, 20, 30])
    print(s.pop!())
    print(s.pop!())
    print(s.pop!())
