// `@T has +` and `@T has ==` are now enforced at call sites.
// This file exercises the *passing* cases (compile + run); failing cases
// are covered by tests/errors/err_has_constraint*.mix.

@T has +
sum_first_two(xs: [T]) -> T
    xs[0] + xs[1]

@T has ==
contains_first(xs: [T], val: T) -> bool
    xs[0] == val

main()
    print(sum_first_two([3, 4]))
    print(contains_first([10, 20, 30], 10))
    print(contains_first([10, 20, 30], 99))
