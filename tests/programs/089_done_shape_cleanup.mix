// Regression: `done` must run the same refcount epilogue as the normal
// function exit path. Before the QBE fix, both `done` and `done expr`
// emitted a raw `ret`, leaking owned shape locals on every early return.

shape Token
    id: int

leave_void()
    t = Token(id: 1)
    done

leave_value() -> int
    t = Token(id: 2)
    done t.id

main()
    a0 = _mix_rc_alloc_count()
    f0 = _mix_rc_free_count()

    i! = 0
    while i < 50
        leave_void()
        leave_value()
        i = i + 1

    a1 = _mix_rc_alloc_count()
    f1 = _mix_rc_free_count()
    print(a1 - a0)      // 100 shape allocs
    print(f1 - f0)      // all 100 released by early-return cleanup
