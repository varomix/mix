{
  "name": "mix-lang",
  "displayName": "MIX Language",
  "description": "MIX language support: syntax highlighting, diagnostics, hover",
  "version": "0.3.0",
  "publisher": "varomix",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:mix"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mix",
        "aliases": [
          "MIX",
          "mix"
        ],
        "extensions": [
          ".mix"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mix",
        "scopeName": "source.mix",
        "path": "./syntaxes/mix.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "MIX",
      "properties": {
        "mix.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the mix-lsp binary. Leave empty to use mix-lsp from PATH."
        },
        "mix.lsp.env": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional environment variables to pass to mix-lsp. Merged with (and overriding) the system environment. Example: {\"CPPFLAGS\": \"-I/opt/homebrew/include\"}"
        }
      }
    },
    "configurationDefaults": {
      "[mix]": {
        "editor.quickSuggestions": {
          "strings": "on"
        },
        "editor.inlayHints.enabled": "on",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "varomix.mix-lang"
      }
    },
    "commands": [
      {
        "command": "mix.restartServer",
        "title": "MIX: Restart Language Server"
      },
      {
        "command": "mix.showOutput",
        "title": "MIX: Show Server Output"
      },
      {
        "command": "mix.toggleInlayHints",
        "title": "MIX: Toggle Inlay Hints"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "brace-expansion": "2.0.3"
  }
}
