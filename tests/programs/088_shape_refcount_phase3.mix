// Refcount Phase 3 — verify shape-list retain/release lifecycle.
//
// Lists of shape elements use mix_list_new_shape, which sets a per-list
// flag so push/set/remove retain/release elements:
//   - push:   list retains; release-after-push drops the SHAPE_LIT temp
//   - pop:    transfers ownership to caller; if discarded as an
//             expression statement, release-on-discard frees it
//   - set:    retains new + releases old
//   - remove: releases the dropped element

shape Item
    id: int

main()
    a0 = _mix_rc_alloc_count()
    f0 = _mix_rc_free_count()

    items! = [Item(id: 0)]    // seed (so list infers element type [Item])
    items.pop!()              // discard seed → release on discard

    // Push 100 SHAPE_LITs into a shape list. Each:
    //   1. mix_shape_alloc (alloc++, refcount=1)
    //   2. mix_list_push retains (refcount=2)
    //   3. release-after-push drops temp (refcount=1)
    // Net: list owns each (refcount 1).
    i! = 0
    while i < 100
        items.push!(Item(id: i))
        i! = i + 1

    a1 = _mix_rc_alloc_count()
    f1 = _mix_rc_free_count()
    print(a1 - a0)            // 101  (seed + 100 pushed)
    print(f1 - f0)             // 1   (seed freed by discard release)
    print(items.len)           // 100

    // Drain via pop + discard. Each pop transfers ownership, the
    // expression-statement discard release frees it. List ends empty,
    // every Item freed.
    while items.len > 0
        items.pop!()
    a2 = _mix_rc_alloc_count()
    f2 = _mix_rc_free_count()
    print(a2 - a0)            // 101  (no new allocs)
    print(f2 - f0)             // 101 (all 101 Items freed)

    // Sanity: int list still works (non-shape path).
    a3 = _mix_rc_alloc_count()
    nums! = [1, 2, 3]
    nums.push!(4)
    nums.push!(5)
    a4 = _mix_rc_alloc_count()
    print(a4 - a3)             // 0
    print(nums.len)            // 5
