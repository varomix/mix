// error propagation with ? operator
parse_positive(x: int) -> int ~
    if x < 0
        fail "negative"
    done x * 10

double_positive(x: int) -> int ~
    val = parse_positive(x)?
    done val * 2

main()
    // Successful propagation
    r1 = double_positive(5) else -1
    print(r1)

    // Failed propagation — error propagates through ?
    r2 = double_positive(-3) else -1
    print(r2)

    // Direct else on parse_positive
    r3 = parse_positive(7) else 0
    print(r3)

    print("done")
