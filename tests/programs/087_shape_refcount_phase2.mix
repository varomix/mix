// Refcount Phase 2 — verify that nested-shape constructor temporaries
// are released after they're memcpy'd into their parent.
//
// Before Phase 2: `Sprite(pos: Vec2(...))` allocated a Vec2 (refcount=1),
// memcpy'd it into the Sprite's pos bytes, and never released the
// temp — leak per construction. Same for `s.pos = Vec2(...)`.
//
// After Phase 2: codegen detects "owned" sources (SHAPE_LIT or shape-
// returning calls) and emits mix_release after the memcpy.
//
// _mix_rc_alloc_count() and _mix_rc_free_count() are runtime-internal
// counters that increment on every mix_shape_alloc / mix_shape_free.
// Used here to assert exact memory accounting.

shape Vec2
    x: float
    y: float

shape Sprite
    pos: Vec2
    width: float
    height: float

main()
    a0 = _mix_rc_alloc_count()
    f0 = _mix_rc_free_count()

    // Construct 100 sprites with inline Vec2s. Without Phase 2, this
    // leaked 100 Vec2 temps. With Phase 2 the temps are released after
    // memcpy. Sprite parents still leak (Phase 3 closes that).
    i! = 0
    while i < 100
        s = Sprite(pos: Vec2(x: 1.0, y: 2.0), width: 16.0, height: 16.0)
        i! = i + 1

    a1 = _mix_rc_alloc_count()
    f1 = _mix_rc_free_count()

    // 100 Sprites + 100 Vec2 temps = 200 allocs in the loop.
    print(a1 - a0)                      // 200
    // 100 Vec2 temps freed (Phase 2) + 99 Sprite reassignment frees
    // (Phase 3.5: each loop iter releases the previous slot value
    // before assigning the new). The 100th Sprite stays in slot s
    // until main's scope-exit (after this print).
    print(f1 - f0)                      // 199

    // Now field assignment with inline shape: `sprite.pos = Vec2(...)`.
    // Same fix applies; the assigned-to Vec2 temp is released after
    // memcpy.
    s2! = Sprite(pos: Vec2(x: 0.0, y: 0.0), width: 8.0, height: 8.0)
    a2 = _mix_rc_alloc_count()
    f2 = _mix_rc_free_count()
    j! = 0
    while j < 50
        s2.pos = Vec2(x: to_float(j), y: 0.0)
        j! = j + 1
    a3 = _mix_rc_alloc_count()
    f3 = _mix_rc_free_count()
    // 50 Vec2 temps allocated, 50 freed (sprite parent unchanged).
    print(a3 - a2)                      // 50
    print(f3 - f2)                      // 50
