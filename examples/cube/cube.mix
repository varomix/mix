use c "cube.h" source "examples/cube/cube.c"

update()
    speed = get_rot_speed()
    rx = get_rx() + 0.01 * speed
    ry = get_ry() + 0.02 * speed
    rz = get_rz() + 0.005 * speed
    set_rx(rx)
    set_ry(ry)
    set_rz(rz)
    gfx_set_rotation(rx, ry, rz)

main()
    gfx_init(800, 600)
    gfx_start_loop()
