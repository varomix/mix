// Variable shadowing — `x = 1` then `x! = 2` works in both backends.
// Regression test for the C backend bug where this caused `redefinition of 'v_x'`.

main()
    x = 1
    print(x)
    x! = 2
    print(x)
    x = 99
    print(x)

    // Type-changing shadow
    y = 7
    print(y)
    y! = "seven"
    print(y)
