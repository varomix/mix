shape Vec2
    x: float
    y: float

shape Sprite
    pos: Vec2
    vel: Vec2

    update(dt: float) !
        pos!.x += vel.x * dt
        pos!.y += vel.y * dt

main() ~
    frame = zone_create("frame", 4096)
    long = zone_create("long", 4096)

    a! = box(frame, Sprite(
        pos: Vec2(x: 1.0, y: 2.0),
        vel: Vec2(x: 3.0, y: 4.0)
    ))
    b = promote(long, a)

    a.update!(2.0)

    print(a.pos.x)
    print(a.pos.y)
    print(b.pos.x)
    print(b.pos.y)

    zone_reset(frame)
    print(b.pos.x)
    print(b.pos.y)

    zone_destroy(frame)
    zone_destroy(long)
