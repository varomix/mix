// Value-shape basics — verifies that plain shapes still behave like
// ordinary values after the refcounted-shape scaffolding is removed.
//
// Here we just confirm:
//   1. Shape construction with fields still works.
//   2. Field reads return the values written.
//   3. Multiple shapes can coexist.
//   4. Shapes returned from functions still carry the right values.

shape Vec2
    x: float
    y: float

shape Box
    pos: Vec2
    width: int
    height: int

make_vec(x: float, y: float) -> Vec2
    Vec2(x: x, y: y)

main()
    a = Vec2(x: 1.0, y: 2.0)
    print(a.x)                    // 1
    print(a.y)                    // 2

    b = make_vec(3.5, 4.5)
    print(b.x)                    // 3.5
    print(b.y)                    // 4.5

    box = Box(pos: Vec2(x: 10.0, y: 20.0), width: 100, height: 200)
    print(box.pos.x)              // 10
    print(box.pos.y)              // 20
    print(box.width)              // 100
    print(box.height)             // 200
